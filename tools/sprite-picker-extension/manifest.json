{
  "manifest_version": 3,
  "name": "Sprite Picker",
  "version": "1.0",
  "description": "Detect and select sprites from sprite sheet images, send them to the Atlas Manager in level-editor.html",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://spriters-resource.com/*",
    "*://www.spriters-resource.com/*",
    "*://images.spriters-resource.com/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://spriters-resource.com/*",
        "*://www.spriters-resource.com/*"
      ],
      "js": ["lib/sprite-detect.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:*/*"],
      "include_globs": ["*level-editor*"],
      "js": ["bridge/level-editor-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
